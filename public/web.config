<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="Angular SPA Fallback" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <!-- Do not rewrite requests for real files (js, css, images, etc.) -->
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <!-- Do not rewrite requests for real directories -->
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <!-- Rewrite to index.html so Angular router can handle the route -->
          <action type="Rewrite" url="/selfregistration/index.html" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
